<CalcLayout>:
    orientation: "vertical"

    TextInput:
        id: input
        font_size: 32
        multiline: False

    GridLayout:
        cols: 4

        Button: text: "1"; on_press: root.tambah("1")
        Button: text: "2"; on_press: root.tambah("2")
        Button: text: "3"; on_press: root.tambah("3")
        Button: text: "+"; on_press: root.tambah("+")

        Button: text: "4"; on_press: root.tambah("4")
        Button: text: "5"; on_press: root.tambah("5")
        Button: text: "6"; on_press: root.tambah("6")
        Button: text: "-"; on_press: root.tambah("-")

        Button: text: "7"; on_press: root.tambah("7")
        Button: text: "8"; on_press: root.tambah("8")
        Button: text: "9"; on_press: root.tambah("9")
        Button: text: "*"; on_press: root.tambah("*")

        Button: text: "C"; on_press: root.hapus()
        Button: text: "0"; on_press: root.tambah("0")
        Button: text: "="; on_press: root.hitung()
        Button: text: "/"; on_press: root.tambah("/")
